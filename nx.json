{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": ["{workspaceRoot}/bun.lock", "{workspaceRoot}/tsconfig.base.json"],
    "production": ["!{projectRoot}/**/*.spec.ts", "!{projectRoot}/**/*.test.ts"]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["{projectRoot}/dist", "{projectRoot}/.nx/cache"]
    },
    "test": {
      "cache": true,
      "inputs": ["default", "^production"],
      "outputs": []
    },
    "typecheck": {
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "lint": {
      "cache": true,
      "inputs": ["default"]
    },
    "dev": {
      "cache": false
    }
  },
  "defaultBase": "origin/main",
  "useInferencePlugins": false,
  "inferFromPackageJson": true
}
