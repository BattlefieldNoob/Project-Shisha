{
  "name": "@project-shisha/shared-config",
  "version": "1.0.0",
  "description": "Shared ESLint and TypeScript configurations for Project Shisha",
  "type": "module",
  "main": "./eslint.config.js",
  "exports": {
    "./eslint": "./eslint.config.js",
    "./tsconfig": "./tsconfig.base.json",
