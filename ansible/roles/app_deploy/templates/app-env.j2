# Environment variables for {{ app_name }}
# Generated by Ansible app_deploy role
# Strategy: {{ dockerfile_strategy }}

# Application settings
APP_NAME={{ app_name }}
APP_PORT={{ app_port }}

# Deployment metadata
DEPLOYMENT_STRATEGY={{ dockerfile_strategy }}
DEPLOYMENT_TIMESTAMP={{ ansible_date_time.iso8601 }}
DEPLOYMENT_BACKUP={{ backup_timestamp | default('none') }}

# Container settings
CONTAINER_NAME={{ container_name }}
IMAGE_REPOSITORY={{ image_repository }}
IMAGE_TAG={{ image_tag }}

# Docker Compose settings
COMPOSE_PROJECT_NAME={{ compose_project_name }}
RESTART_POLICY={{ restart_policy }}

# Watchtower settings
WATCHTOWER_ENABLED={{ watchtower_enabled | lower }}

# Rolling update settings (if enabled)
{% if rolling_update_enabled %}
ROLLING_UPDATE_ENABLED=true
ROLLING_UPDATE_DELAY={{ rolling_update_delay }}
{% endif %}
