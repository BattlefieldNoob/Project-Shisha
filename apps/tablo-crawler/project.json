{
  "name": "tablo-crawler",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/tablo-crawler",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun build src/index.ts --compile --outfile dist/index",
        "cwd": "apps/tablo-crawler",
        "cache": true
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run src/index.ts",
        "cwd": "apps/tablo-crawler"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test",
        "cwd": "apps/tablo-crawler"
      },
      "cache": true
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "apps/tablo-crawler"
      },
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx eslint src/ --fix",
        "cwd": "apps/tablo-crawler"
      },
      "cache": true
    },
    "docker:build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -t tablo-crawler -f Dockerfile .",
        "cwd": "apps/tablo-crawler"
      }
    }
  },
  "implicitDependencies": ["shared-lib", "shared-config"]
}
