# TabloCrawler Runbook Environment Variables Template
# Copy this file to runbook.env and fill in your values

# =============================================================================
# TABLO API CONFIGURATION
# =============================================================================
# Required: Your Tablo authentication token
TABLO_AUTH_TOKEN=your_auth_token_here

# =============================================================================
# TELEGRAM NOTIFICATION CONFIGURATION (Optional)
# =============================================================================
# Telegram bot token for notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Telegram chat ID for receiving notifications
TELEGRAM_CHAT_ID=your_telegram_chat_id

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Number of days to scan ahead (1-7)
DAYS_TO_SCAN=3

# Minimum number of participants required
MIN_PARTICIPANTS=2

# Maximum distance in kilometers for filtering
MAX_DISTANCE=10.0

# Scan interval in seconds for watch mode
INTERVAL_SECONDS=300

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
# SSH configuration for Raspberry Pi deployment
SSH_USER=pi
SSH_HOST=your_raspberry_pi_ip
SSH_KEY_PATH=~/.ssh/id_rsa

# Ansible configuration
ANSIBLE_HOST_KEY_CHECKING=False
ANSIBLE_INVENTORY=deploy/inventory.yml
ANSIBLE_VAULT_PASSWORD_FILE=deploy/.vault_pass

# Docker registry configuration (if using private registry)
DOCKER_REGISTRY=
DOCKER_USERNAME=
DOCKER_PASSWORD=

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
# Log level for application (debug, info, warn, error)
LOG_LEVEL=info

# Health check endpoints
HEALTH_CHECK_URL=http://localhost:3000/health
HEALTH_CHECK_INTERVAL=60

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
# Development mode settings
NODE_ENV=development
DEBUG=tabloCrawler:*

# Test configuration
TEST_TIMEOUT=30000
TEST_RESTAURANT_ID=12345