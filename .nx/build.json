{
  "$schema": "https://nx.dev/schema/nx-plugin.json",
  "buildType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc",
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "outputs": ["{projectRoot}/dist"]
    },
    "build:app": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun build src/index.ts --outdir dist --target node --format esm",
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "outputs": ["{projectRoot}/dist"]
    },
    "build:compile": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun build src/index.ts --compile --outfile dist/index",
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "outputs": ["{projectRoot}/dist"]
    }
  }
}
